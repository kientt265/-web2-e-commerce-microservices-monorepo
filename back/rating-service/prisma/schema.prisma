generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model product_ratings {
  id                  Int                  @id @default(autoincrement())
  product_id          Int
  user_id             String               @db.Uuid

  rating              Int
  title               String?
  comment             String?
  images              String[]             @default([])

  is_anonymous        Boolean              @default(false)
  is_published        Boolean              @default(true)
  reported            Boolean              @default(false)

  order_id            Int?
  created_at          DateTime?            @default(now()) @db.Timestamp(6)
  updated_at          DateTime?            @default(now()) @updatedAt @db.Timestamp(6)

  // back relation: helpful votes for this rating
  helpful_votes       rating_helpful_votes[]

  @@index([product_id])
  @@index([user_id])
  @@unique([product_id, user_id, order_id])
}

model rating_helpful_votes {
  id             Int              @id @default(autoincrement())
  rating_id      Int
  user_id        String           @db.Uuid
  is_helpful     Boolean          @default(true)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)

  rating         product_ratings  @relation(fields: [rating_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([rating_id, user_id])
}